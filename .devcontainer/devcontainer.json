{
    "dockerComposeFile": "./docker-compose.dev.yaml",
    "name": "booking-app",
    "service": "booking-app",
    "workspaceFolder": "/app",
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/nils-geistmann/devcontainers-features/zsh:0.0.8": {}
    },
    "mounts": [
        "source=${env:SSH_AUTH_SOCK},target=/ssh-agent,consistency=cached,type=bind"
    ],
    "remoteEnv": {
        "SSH_AUTH_SOCK": "/ssh-agent"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.Go",
                "usernamehw.errorlens"
            ],
            "settings": {
                "editor.formatOnSave": true
            }
        }
    },
    "postCreateCommand": "mkdir -p /app && go install github.com/go-delve/delve/cmd/dlv@latest"
}